interface ProductInterface {
  attributes: [Attribute]
  @resolver(
    class: "Appstractsoftware\\MagentoAdapter\\CustomGQL\\Model\\Resolver\\AttributesResolver"
  )
}

type CustomerOrder
@doc(description: "Contains details about each of the customer's orders") {
  items: [OrderItemInterface]
  @doc(description: "An array containing the items purchased in this order")
  @resolver(
    class: "Appstractsoftware\\MagentoAdapter\\CustomGQL\\Model\\Resolver\\OrderItemsResolver"
  )
}

type Attribute {
  code: String
  value: String
  type: String
  swatch: String
}

type Aggregation {
  type: String
}

interface AggregationOptionInterface {
  swatch_value: String
}

interface OrderItemInterface
@doc(description: "Order item details")
@typeResolver(class: "Magento\\SalesGraphQl\\Model\\TypeResolver\\OrderItem") {
  product_image: String
  product_options: [OrderItemOptions]
}

type OrderItemOptions {
  label: String
  value: String
}
